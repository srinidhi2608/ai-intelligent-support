# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the application.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model name served by Ollama (e.g. deepseek-r1, llama3, mistral)
LLM_MODEL=deepseek-r1

# FastAPI application settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
