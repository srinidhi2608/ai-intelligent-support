# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the application.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API key used by the LangChain agents
OPENAI_API_KEY=sk-your-openai-api-key-here

# (Optional) Google Gemini API key – alternative LLM provider
GEMINI_API_KEY=your-gemini-api-key-here

# LLM model name (e.g. gpt-4o, gpt-3.5-turbo, gemini-pro)
LLM_MODEL=gpt-4o

# FastAPI application settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
