# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the application.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Local tool-calling model served by Ollama.
# Must support native function/tool calling (e.g. llama3.1, qwen2.5, mistral).
# Pull with: ollama pull llama3.1
LLM_MODEL=llama3.1

# FastAPI application settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
