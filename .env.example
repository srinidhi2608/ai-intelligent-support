# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the application.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Reasoning-only model (used by SupportAgent & RiskAgent – no tool calling)
LLM_MODEL=deepseek-r1

# Tool-capable model (used by the ReAct agent orchestrator & Streamlit app)
# Must support native tool/function calling (e.g. llama3.1, qwen2.5, mistral)
TOOL_LLM_MODEL=llama3.1

# FastAPI application settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
